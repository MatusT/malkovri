{
  "name": "malkovri-wgsl-debugger",
  "displayName": "Malkovri WGSL Debugger",
  "description": "Malkovri WGSL Debugger",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.103.0"
  },
  "publisher": "mallumo",
  "categories": [
    "Debuggers"
  ],
  "activationEvents": ["onDebug"],
  "main": "./out/extension.js",
  "contributes": {
    "debuggers": [
      {
        "type": "wgsl",
        "label": "WGSL Debugger",

        "languages": ["wgsl"],

        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to the WGSL shader file to debug."
              },
              "global_invocation_id": {
                "type": "array",
                "items": { "type": "integer", "minimum": 0 },
                "default": [0, 0, 0],
                "description": "The @builtin(global_invocation_id) value passed to the entry point."
              },
              "bindings": {
                "type": "object",
                "description": "WebGPU resource bindings, keyed by 'group:binding' (e.g. '0:0').",
                "additionalProperties": {
                  "type": "object",
                  "required": ["type"],
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": ["f32", "i32", "u32"],
                      "description": "Scalar element type of the buffer."
                    },
                    "inline": {
                      "type": "array",
                      "description": "Inline array of values. Cannot be combined with 'file'."
                    },
                    "file": {
                      "type": "string",
                      "description": "Path to a data file (relative to the shader). Cannot be combined with 'inline'."
                    },
                    "format": {
                      "type": "string",
                      "enum": ["ron", "binary"],
                      "default": "ron",
                      "description": "File format: 'ron' (RON array, default) or 'binary' (little-endian 4-byte values)."
                    }
                  }
                }
              }
            }
          }
        },

        "initialConfigurations": [
          {
            "type": "wgsl",
            "request": "launch",
            "name": "Launch Program",
            "program": "${workspaceFolder}/shader.wgsl"
          }
        ]
      }
    ],
    "breakpoints": [
      {
        "language": "wgsl"
      }
    ],
    "commands": [
      {
        "command": "malkovri-wgsl-debugger.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.103.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^9.32.0",
    "typescript": "^5.9.2",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
